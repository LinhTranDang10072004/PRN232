@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var unread = ViewBag.UnreadCount as int? ?? 0;

    string NavClass(string navController, string? navAction = null)
    {
        if (!string.Equals(controller, navController, StringComparison.OrdinalIgnoreCase))
            return "nav-link";
        if (navAction != null && !string.Equals(action, navAction, StringComparison.OrdinalIgnoreCase))
            return "nav-link";
        return "nav-link active";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Chi phí công ty</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/personal.css" asp-append-version="true" />
</head>
<body class="personal-app staff-app">
    <header class="personal-app-nav">
        <div class="personal-app-nav-inner">
            <a class="personal-app-brand" asp-area="Staff" asp-controller="Dashboard" asp-action="Index">
                <span class="personal-app-brand-icon">🏢</span>
                Expense Corporate — Staff
            </a>
            <div class="personal-app-actions">
                <partial name="_UserInfo" />
                <a class="personal-notify-btn" asp-area="Staff" asp-controller="Notifications" asp-action="Index" title="Thông báo">
                    🔔
                    @if (unread > 0)
                    {
                        <span class="personal-notify-badge">@unread</span>
                    }
                </a>
                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-ghost btn-sm">Đăng xuất</button>
                </form>
            </div>
        </div>
    </header>

    <div class="personal-layout">
        <aside class="personal-sidebar">
            <nav class="personal-nav">
                <a class="@NavClass("Dashboard")" asp-area="Staff" asp-controller="Dashboard" asp-action="Index">📊 Tổng quan</a>
                <a class="@NavClass("Expenses", "Index")" asp-area="Staff" asp-controller="Expenses" asp-action="Index">📋 Phiếu chi</a>
                <a class="@NavClass("Expenses", "Create")" asp-area="Staff" asp-controller="Expenses" asp-action="Create">➕ Tạo phiếu chi</a>
                <a class="@NavClass("Notifications")" asp-area="Staff" asp-controller="Notifications" asp-action="Index">🔔 Thông báo</a>
                <a class="@NavClass("Profile")" asp-area="Staff" asp-controller="Profile" asp-action="Index">👤 Hồ sơ</a>
            </nav>
        </aside>
        <main class="personal-main">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
