@model StaffDashboardDto
@{
    ViewData["Title"] = "Tổng quan";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Tổng quan phiếu chi</h2>
        <p class="page-subtitle">Theo dõi trạng thái phiếu chi của bạn</p>
    </div>
</div>

<div class="row g-3 stats-row">
    <div class="col-md-3">
        <div class="card stat-card shadow-sm stat-card-accent-warning">
            <div class="card-body">
                <div class="text-muted small">Chờ duyệt</div>
                <div class="fs-3 fw-bold text-warning">@Model.PendingCount</div>
                <div class="small text-muted">@Model.TotalPendingAmount.ToString("N0") đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow-sm stat-card-accent-success">
            <div class="card-body">
                <div class="text-muted small">Đã duyệt</div>
                <div class="fs-3 fw-bold text-success">@Model.ApprovedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow-sm stat-card-accent-danger">
            <div class="card-body">
                <div class="text-muted small">Bị từ chối</div>
                <div class="fs-3 fw-bold text-danger">@Model.RejectedCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Thông báo chưa đọc</div>
                <div class="fs-3 fw-bold">@(ViewBag.UnreadCount ?? 0)</div>
            </div>
        </div>
    </div>
</div>

<div class="quick-actions">
    <a asp-controller="Expenses" asp-action="Create" class="btn btn-primary">➕ Tạo phiếu chi mới</a>
    <a asp-controller="Expenses" asp-action="Index" class="btn btn-outline-primary">📋 Xem danh sách</a>
</div>
