@model List<ClientMVC.Models.Admin.StaffUserDto>
@{
    ViewData["Title"] = "Nhân viên";
}

<div class="page-header">
    <h2 class="page-title">👥 Nhân viên</h2>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">+ Tạo Staff</a>
    </div>
</div>

<div class="card shadow-sm data-table-card">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Tên đăng nhập</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.UserName</td>
                    <td>@(s.FullName ?? "—")</td>
                    <td>@s.Email</td>
                    <td>
                        @if (s.IsActive)
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Khóa</span>
                        }
                    </td>
                    <td class="text-end">
                        <form asp-action="ToggleActive" method="post" class="d-inline"
                              onsubmit="return confirm('@(s.IsActive ? "Khóa tài khoản nhân viên này?" : "Mở khóa tài khoản nhân viên này?")');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@s.Id" />
                            <input type="hidden" name="isActive" value="@((!s.IsActive).ToString().ToLower())" />
                            <button type="submit" class="btn btn-sm btn-outline-warning">
                                @(s.IsActive ? "Khóa" : "Mở khóa")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-muted mt-3">Chưa có nhân viên. <a asp-action="Create">Tạo Staff đầu tiên</a></p>
}
