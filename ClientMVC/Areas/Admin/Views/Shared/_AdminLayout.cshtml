@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var status = ViewContext.HttpContext.Request.Query["status"].ToString();

    string NavClass(string navController, string? navAction = null, string? navStatus = null)
    {
        if (!string.Equals(controller, navController, StringComparison.OrdinalIgnoreCase))
            return "nav-link";
        if (navAction != null && !string.Equals(action, navAction, StringComparison.OrdinalIgnoreCase))
            return "nav-link";
        if (navStatus != null && status != navStatus)
            return "nav-link";
        if (navStatus == null && navController == "Expenses" && !string.IsNullOrEmpty(status))
            return "nav-link";
        return "nav-link active";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/personal.css" asp-append-version="true" />
</head>
<body class="personal-app admin-app">
    <header class="personal-app-nav">
        <div class="personal-app-nav-inner">
            <a class="personal-app-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="personal-app-brand-icon">🏢</span>
                Expense Corporate — Admin
            </a>
            <div class="personal-app-actions">
                <partial name="_UserInfo" />
                <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-ghost btn-sm">Đăng xuất</button>
                </form>
            </div>
        </div>
    </header>

    <div class="personal-layout">
        <aside class="personal-sidebar">
            <nav class="personal-nav">
                <a class="@NavClass("Dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">📊 Tổng quan</a>
                <a class="@NavClass("Expenses", "Index")" asp-area="Admin" asp-controller="Expenses" asp-action="Index">📋 Duyệt phiếu chi</a>
                <a class="@NavClass("Expenses", "Index", "pending")" asp-area="Admin" asp-controller="Expenses" asp-action="Index" asp-route-status="pending">⏳ Chờ duyệt</a>
                <a class="@NavClass("Staff")" asp-area="Admin" asp-controller="Staff" asp-action="Index">👥 Nhân viên</a>
                <a class="@NavClass("Categories")" asp-area="Admin" asp-controller="Categories" asp-action="Index">🏷️ Danh mục</a>
                <a class="@NavClass("Accounts")" asp-area="Admin" asp-controller="Accounts" asp-action="Index">🏦 Tài khoản</a>
            </nav>
        </aside>
        <main class="personal-main">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
