@model ClientMVC.Models.Admin.AdminCategoryFormModel
@using BusinessObjects.Enums
@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="page-header">
    <h2 class="page-title">Thêm danh mục</h2>
</div>
<form asp-action="Create" method="post" class="card p-4 shadow-sm personal-form-card personal-form-xs">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-2">
        <label asp-for="Name" class="form-label">Tên</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Status" class="form-label">Trạng thái</label>
        <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<CategoryStatus>()"></select>
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
