@model List<ClientMVC.Models.Admin.AdminCategoryDto>
@using BusinessObjects.Enums
@{
    ViewData["Title"] = "Danh mục công ty";
}

<div class="page-header">
    <h2 class="page-title">🏷️ Danh mục công ty</h2>
    <div class="page-actions">
        <a asp-action="Create" class="btn btn-primary">+ Thêm</a>
    </div>
</div>

<div class="card shadow-sm data-table-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>Tên</th><th>Trạng thái</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Name</td>
                        <td><span class="badge bg-secondary">@c.Status</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa danh mục?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
