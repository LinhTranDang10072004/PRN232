@model ClientMVC.Models.Corporate.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Admin";
}

<div class="p-4 mb-4 bg-dark text-white rounded-3">
    <h1 class="display-6">Dashboard Admin</h1>
    <p class="mb-0">Nhánh 2 — Quản lý công ty</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center h-100 border-dark">
            <div class="card-body">
                <h3 class="text-dark">@Model.StaffCount</h3>
                <p class="mb-0">Nhân viên</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100 border-warning">
            <div class="card-body">
                <h3 class="text-warning">@Model.PendingCount</h3>
                <p class="mb-0">Chờ duyệt (tháng)</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <h3>@Model.MonthExpenseCount</h3>
                <p class="mb-0">Khoản chi tháng</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <h3>@Model.MonthTotalAmount.ToString("N0")</h3>
                <p class="mb-0">Tổng tiền (đ)</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5>Lịch duyệt chi tiêu</h5>
                <p class="text-muted">Xem theo tháng/ngày, chấp nhận hoặc từ chối.</p>
                <a asp-area="Corporate" asp-controller="AdminExpenses" asp-action="Calendar" class="btn btn-success">Mở lịch duyệt</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5>Quản lý nhân viên</h5>
                <p class="text-muted">Cấp tài khoản Staff (không tự đăng ký).</p>
                <a asp-area="Corporate" asp-controller="AdminStaffs" asp-action="Index" class="btn btn-dark">Quản lý Staff</a>
            </div>
        </div>
    </div>
</div>
