@model ClientMVC.Models.Corporate.CorporateCalendarViewModel
@{
    ViewData["Title"] = "Duyệt chi tiêu — Admin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Duyệt chi tiêu nhân viên</h2>
    <span class="badge bg-warning text-dark fs-6">Chờ duyệt tháng: @Model.PendingCount</span>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage)) { <div class="alert alert-success">@Model.SuccessMessage</div> }
@if (!string.IsNullOrEmpty(Model.ErrorMessage)) { <div class="alert alert-danger">@Model.ErrorMessage</div> }

<partial name="~/Areas/Corporate/Views/Shared/_CalendarFilters.cshtml" />
<partial name="~/Areas/Corporate/Views/Shared/_CalendarMonth.cshtml" />

<div class="card border-success">
    <div class="card-header bg-success text-white">
        <strong>Chi tiết ngày @Model.SelectedDay/@Model.Month/@Model.Year</strong>
        <span class="badge bg-light text-dark ms-2">@Model.DayExpenses.Count khoản</span>
    </div>
    <div class="card-body p-0">
        @if (Model.DayExpenses.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Không có chi tiêu.</p>
        }
        <div class="list-group list-group-flush">
        @foreach (var e in Model.DayExpenses)
        {
            var badge = e.Status switch { "Approved" => "success", "Rejected" => "danger", _ => "warning" };
            <div class="list-group-item">
                <div class="d-flex justify-content-between flex-wrap gap-2">
                    <div>
                        <span class="badge bg-secondary">@e.StaffUsername</span>
                        @(string.IsNullOrEmpty(e.StaffFullName) ? "" : $" ({e.StaffFullName})")
                        <br /><strong>@e.Title</strong> — @e.CategoryName
                        <br />@e.Amount.ToString("N0") đ · <span class="badge bg-@badge">@e.Status</span>
                        @if (!string.IsNullOrEmpty(e.RejectionReason))
                        {
                            <br /><small class="text-danger">@e.RejectionReason</small>
                        }
                    </div>
                    @if (e.Status == "Pending")
                    {
                        <div class="text-nowrap">
                            <form asp-action="Approve" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Id" />
                                <input type="hidden" name="year" value="@Model.Year" />
                                <input type="hidden" name="month" value="@Model.Month" />
                                <input type="hidden" name="day" value="@Model.SelectedDay" />
                                <input type="hidden" name="filterKeyword" value="@Model.Filters.FilterKeyword" />
                                <input type="hidden" name="filterCategoryId" value="@Model.Filters.FilterCategoryId" />
                                <input type="hidden" name="filterStatus" value="@Model.Filters.FilterStatus" />
                                <input type="hidden" name="filterMinAmount" value="@Model.Filters.FilterMinAmount" />
                                <button type="submit" class="btn btn-sm btn-success"
                                        onclick="return confirm('Chấp nhận khoản chi này?');">Chấp nhận</button>
                            </form>
                            <button type="button" class="btn btn-sm btn-danger"
                                    data-bs-toggle="modal" data-bs-target="#rejectModal"
                                    onclick="setReject(@e.Id)">Từ chối</button>
                        </div>
                    }
                </div>
            </div>
        }
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="Reject" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="rejectId" />
            <input type="hidden" name="year" value="@Model.Year" />
            <input type="hidden" name="month" value="@Model.Month" />
            <input type="hidden" name="day" value="@Model.SelectedDay" />
            <input type="hidden" name="filterKeyword" value="@Model.Filters.FilterKeyword" />
            <input type="hidden" name="filterCategoryId" value="@Model.Filters.FilterCategoryId" />
            <input type="hidden" name="filterStatus" value="@Model.Filters.FilterStatus" />
            <input type="hidden" name="filterMinAmount" value="@Model.Filters.FilterMinAmount" />
            <div class="modal-header">
                <h5 class="modal-title">Từ chối khoản chi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Lý do *</label>
                <textarea name="rejectReason" class="form-control" rows="3" required></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="submit" class="btn btn-danger">Xác nhận từ chối</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function setReject(id) { document.getElementById('rejectId').value = id; }
    @if (Model.ReviewExpenseId.HasValue)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function () {
            setReject(@Model.ReviewExpenseId);
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        });
        </text>
    }
</script>
}
