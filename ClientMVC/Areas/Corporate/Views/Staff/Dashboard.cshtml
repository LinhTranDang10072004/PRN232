@model ClientMVC.Models.Corporate.StaffDashboardViewModel
@{
    ViewData["Title"] = "Dashboard Staff";
}

<div class="p-4 mb-4 bg-info text-dark rounded-3">
    <h1 class="display-6">Dashboard Staff</h1>
    <p class="mb-0">Khai báo chi tiêu → Admin duyệt</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center border-warning">
            <div class="card-body"><h3>@Model.PendingCount</h3><p class="mb-0">Chờ duyệt</p></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center border-success">
            <div class="card-body"><h3>@Model.ApprovedCount</h3><p class="mb-0">Đã duyệt</p></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center border-danger">
            <div class="card-body"><h3>@Model.RejectedCount</h3><p class="mb-0">Từ chối</p></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5>Lịch chi tiêu theo tháng</h5>
        <p class="text-muted">Thêm/sửa/xóa khi chưa Approved. Đã duyệt sẽ khóa.</p>
        <a asp-area="Corporate" asp-controller="StaffExpenses" asp-action="Calendar" class="btn btn-info text-dark btn-lg">Mở lịch chi tiêu</a>
    </div>
</div>
