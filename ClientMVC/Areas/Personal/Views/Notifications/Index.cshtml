@model List<NotificationDto>
@{ ViewData["Title"] = "Thông báo"; }

<div class="d-flex justify-content-between mb-3">
    <h2>🔔 Thông báo</h2>
    <form asp-action="MarkAllRead" method="post">
        @Html.AntiForgeryToken()
        <button class="btn btn-outline-primary btn-sm">Đánh dấu tất cả đã đọc</button>
    </form>
</div>

<div class="list-group shadow-sm">
@foreach (var n in Model)
{
    var itemClass = n.Severity switch
    {
        "danger" => "list-group-item-danger",
        "warning" => "list-group-item-warning",
        _ => n.IsRead ? "" : "list-group-item-light border-start border-primary border-3"
    };
    var titleClass = n.Severity == "danger" ? "text-danger" : n.Severity == "warning" ? "text-warning-emphasis" : "";
    <div class="list-group-item @itemClass">
        <div class="d-flex justify-content-between align-items-start gap-2">
            <div>
                <strong class="@titleClass">@n.Title</strong>
                @if (n.Severity == "danger")
                {
                    <span class="badge bg-danger ms-1">Vượt budget</span>
                }
                @if (!string.IsNullOrEmpty(n.Content))
                {
                    <div class="small @(n.Severity == "danger" ? "text-danger" : "text-muted") mt-1">@n.Content</div>
                }
                <div class="small text-muted">@n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            @if (!n.IsRead)
            {
                <form asp-action="MarkRead" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@n.Id" />
                    <button class="btn btn-sm btn-outline-secondary">Đã đọc</button>
                </form>
            }
        </div>
    </div>
}
</div>

@if (!Model.Any())
{
    <p class="text-muted">Chưa có thông báo.</p>
}
