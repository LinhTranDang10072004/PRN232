@model List<NotificationDto>
@{ ViewData["Title"] = "Thông báo"; }

<div class="d-flex justify-content-between mb-3">
    <h2>🔔 Thông báo</h2>
    <form asp-action="MarkAllRead" method="post">
        @Html.AntiForgeryToken()
        <button class="btn btn-outline-primary btn-sm">Đánh dấu tất cả đã đọc</button>
    </form>
</div>

<div class="list-group shadow-sm">
@foreach (var n in Model)
{
    <div class="list-group-item @(n.IsRead ? "" : "list-group-item-warning")">
        <div class="d-flex justify-content-between">
            <div>
                <strong>@n.Title</strong>
                @if (!string.IsNullOrEmpty(n.Content)) { <div class="small text-muted">@n.Content</div> }
                <div class="small text-muted">@n.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            @if (!n.IsRead)
            {
                <form asp-action="MarkRead" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@n.Id" />
                    <button class="btn btn-sm btn-outline-secondary">Đã đọc</button>
                </form>
            }
        </div>
    </div>
}
</div>
