@model BudgetFormModel
@{ ViewData["Title"] = "Tạo budget"; }

<h2>@ViewData["Title"]</h2>
@if (!string.IsNullOrEmpty(Model.ErrorMessage)) { <div class="alert alert-danger">@Model.ErrorMessage</div> }
<form asp-action="Create" method="post" class="card p-4 shadow-sm" style="max-width:480px">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
    </div>
    <div class="row">
        <div class="col-6 mb-3"><label asp-for="Month" class="form-label"></label><input asp-for="Month" class="form-control" /></div>
        <div class="col-6 mb-3"><label asp-for="Year" class="form-label"></label><input asp-for="Year" class="form-control" /></div>
    </div>
    <div class="mb-3"><label asp-for="LimitAmount" class="form-label"></label><input asp-for="LimitAmount" class="form-control" /></div>
    <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" placeholder="Tùy chọn" /></div>
    <button class="btn btn-primary">Tạo</button>
</form>
