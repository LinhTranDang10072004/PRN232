@using ClientMVC.Helpers
@model ClientMVC.Models.Personal.PersonalCalendarViewModel
@{
    ViewData["Title"] = "Lịch chi tiêu cá nhân";
    var route = CalendarHelper.FilterRouteData(Model.Filters);
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h2 class="mb-0">Ví cá nhân — Lịch chi tiêu</h2>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-1">Xem danh sách</a>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#expenseModal"
                onclick="clearPersonalForm(@Model.Year, @Model.Month, @Model.SelectedDay)">
            + Thêm @Model.SelectedDay/@Model.Month
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage)) { <div class="alert alert-success">@Model.SuccessMessage</div> }
@if (!string.IsNullOrEmpty(Model.ErrorMessage)) { <div class="alert alert-danger">@Model.ErrorMessage</div> }

<div class="alert alert-info py-2 small">Ngày chi tiêu ghi đúng ngày phát sinh — <strong>không nhập ngày tương lai</strong>.</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="year" value="@Model.Year" />
            <input type="hidden" name="month" value="@Model.Month" />
            <input type="hidden" name="day" value="@Model.SelectedDay" />
            <div class="col-md-4">
                <label class="form-label">Tìm tên</label>
                <input name="filterKeyword" value="@Model.Filters.FilterKeyword" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Chủ đề / Danh mục</label>
                <select name="filterCategoryId" class="form-select">
                    <option value="">-- Tất cả --</option>
                    @foreach (var c in Model.Categories)
                    {
                        if (Model.Filters.FilterCategoryId == c.Id)
                        {
                            <option value="@c.Id" selected="selected">@c.Name</option>
                        }
                        else
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Số tiền tối thiểu</label>
                <input name="filterMinAmount" value="@Model.Filters.FilterMinAmount" type="number" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Lọc (OData)</button>
            </div>
        </form>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between mb-3">
            <a class="btn btn-outline-secondary btn-sm" asp-action="Calendar"
               asp-route-year="@(Model.Month == 1 ? Model.Year - 1 : Model.Year)"
               asp-route-month="@(Model.Month == 1 ? 12 : Model.Month - 1)" asp-route-day="1"
               asp-all-route-data="route">‹ Tháng trước</a>
            <h4 class="mb-0">@Model.MonthTitle</h4>
            <a class="btn btn-outline-secondary btn-sm" asp-action="Calendar"
               asp-route-year="@(Model.Month == 12 ? Model.Year + 1 : Model.Year)"
               asp-route-month="@(Model.Month == 12 ? 1 : Model.Month + 1)" asp-route-day="1"
               asp-all-route-data="route">Tháng sau ›</a>
        </div>
        <table class="table table-bordered text-center mb-0">
            <thead class="table-light"><tr><th>CN</th><th>T2</th><th>T3</th><th>T4</th><th>T5</th><th>T6</th><th>T7</th></tr></thead>
            <tbody>
            @for (var i = 0; i < Model.CalendarDays.Count; i += 7)
            {
                <tr>
                @for (var j = i; j < i + 7; j++)
                {
                    if (j < Model.CalendarDays.Count)
                    {
                        var cell = Model.CalendarDays[j];
                        if (cell.Day == null) { <td class="bg-light"></td> }
                        else
                        {
                            <td class="@(cell.IsSelected ? "table-primary" : "") @(cell.IsToday ? "border border-2 border-dark" : "")">
                                <a asp-action="Calendar" asp-route-year="@Model.Year" asp-route-month="@Model.Month"
                                   asp-route-day="@cell.Day" asp-all-route-data="route"
                                   class="d-block text-decoration-none text-dark fw-bold">@cell.Day</a>
                                @if (cell.ExpenseCount > 0)
                                {
                                    <small class="d-block">@cell.ExpenseCount · @cell.TotalAmount.ToString("N0")đ</small>
                                }
                            </td>
                        }
                    }
                    else { <td class="bg-light"></td> }
                }
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="card border-primary">
    <div class="card-header bg-primary text-white">
        Chi tiết ngày @Model.SelectedDay/@Model.Month/@Model.Year
        <span class="badge bg-light text-dark ms-2">@Model.DayExpenses.Count</span>
    </div>
    <div class="card-body p-0">
        @if (Model.DayExpenses.Count == 0)
        {
            <p class="text-muted p-3 mb-0">Chưa có chi tiêu trong ngày này.</p>
        }
        @foreach (var e in Model.DayExpenses)
        {
            <div class="list-group-item d-flex justify-content-between">
                <div>
                    <strong>@e.Title</strong> — @e.CategoryName<br />
                    <span class="text-muted">@e.Amount.ToString("N0") đ</span>
                </div>
                <div>
                    <a asp-action="Calendar" asp-route-editId="@e.Id"
                       asp-route-year="@Model.Year" asp-route-month="@Model.Month" asp-route-day="@Model.SelectedDay"
                       asp-all-route-data="route" class="btn btn-sm btn-outline-secondary">Sửa</a>
                    <form asp-action="DeleteCalendar" method="post" class="d-inline"
                          onsubmit="return confirm('Xóa khoản chi?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@e.Id" />
                        <input type="hidden" name="year" value="@Model.Year" />
                        <input type="hidden" name="month" value="@Model.Month" />
                        <input type="hidden" name="day" value="@Model.SelectedDay" />
                        <input type="hidden" name="filterKeyword" value="@Model.Filters.FilterKeyword" />
                        <input type="hidden" name="filterCategoryId" value="@Model.Filters.FilterCategoryId" />
                        <input type="hidden" name="filterMinAmount" value="@Model.Filters.FilterMinAmount" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="expenseModal" tabindex="-1">
    <div class="modal-dialog">
        <form id="personalForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="year" value="@Model.Year" />
            <input type="hidden" name="month" value="@Model.Month" />
            <input type="hidden" name="day" value="@Model.SelectedDay" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="personalModalTitle">Thêm chi tiêu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-2">
                        <label asp-for="Form.Title" class="form-label">Tên *</label>
                        <input asp-for="Form.Title" class="form-control" />
                        <span asp-validation-for="Form.Title" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Form.Amount" class="form-label">Số tiền *</label>
                        <input asp-for="Form.Amount" type="number" step="1000" min="0.01" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="Form.ExpenseDate" class="form-label">Ngày phát sinh *</label>
                        <input asp-for="Form.ExpenseDate" type="date" class="form-control" max="@Model.MaxDate" />
                        <span asp-validation-for="Form.ExpenseDate" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Form.CategoryId" class="form-label">Chủ đề *</label>
                        <select asp-for="Form.CategoryId" class="form-select"
                                asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"></select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function clearPersonalForm(y, m, d) {
            document.getElementById('personalModalTitle').innerText = 'Thêm chi tiêu';
            document.getElementById('personalForm').action = '@Url.Action("CreateCalendar")';
            document.getElementById('Form_ExpenseDate').value = y + '-' + String(m).padStart(2,'0') + '-' + String(d).padStart(2,'0');
        }
        @if (Model.ShowFormModal) {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                document.getElementById('personalModalTitle').innerText = '@(Model.IsEdit ? "Sửa" : "Thêm")';
                document.getElementById('personalForm').action = '@(Model.IsEdit ? Url.Action("EditCalendar", new { id = Model.Form.Id }) : Url.Action("CreateCalendar"))';
                new bootstrap.Modal(document.getElementById('expenseModal')).show();
            });
            </text>
        }
    </script>
}
