@model List<ExpenseDto>
@{
    ViewData["Title"] = "Danh sách chi tiêu";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Danh sách chi tiêu</h2>
    <div class="d-flex gap-2">
        <a asp-action="Calendar" class="btn btn-outline-primary">📅 Lịch</a>
        <a asp-action="Create" class="btn btn-primary">+ Thêm</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Ngày</th>
                    <th>Tiêu đề</th>
                    <th>Danh mục</th>
                    <th>Ví</th>
                    <th class="text-end">Số tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@(e.ExpenseDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@e.Title</td>
                        <td>@e.CategoryName</td>
                        <td>@(e.WalletName ?? "—")</td>
                        <td class="text-end text-danger">@e.Amount.ToString("N0")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
