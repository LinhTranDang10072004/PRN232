@model CategoryFormModel
@{ ViewData["Title"] = Model.Id.HasValue ? "Sửa danh mục" : "Thêm danh mục"; }

<h2>@ViewData["Title"]</h2>
@if (!string.IsNullOrEmpty(Model.ErrorMessage)) { <div class="alert alert-danger">@Model.ErrorMessage</div> }
<form asp-action="@(Model.Id.HasValue ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post" class="card p-4 shadow-sm" style="max-width:420px">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <button class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
</form>
