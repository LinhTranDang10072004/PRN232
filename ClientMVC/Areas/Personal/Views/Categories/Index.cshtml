@model ClientMVC.Models.Personal.CategoryIndexViewModel
@{
    ViewData["Title"] = "Danh mục";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Danh mục cá nhân</h2>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#categoryModal"
            onclick="clearCategoryForm()">+ Thêm</button>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label">Tìm tên danh mục</label>
                <input name="filterKeyword" value="@Model.FilterKeyword" class="form-control" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">Lọc (OData)</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th>Tên</th>
                <th>Loại</th>
                <th style="width:140px"></th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Items.Count == 0)
        {
            <tr><td colspan="3" class="text-center text-muted">Không có danh mục.</td></tr>
        }
        @foreach (var c in Model.Items)
        {
            <tr>
                <td>@c.Name</td>
                <td>
                    @if (c.IsSystem)
                    {
                        <span class="badge bg-secondary">Hệ thống</span>
                    }
                    else
                    {
                        <span class="badge bg-info">Của tôi</span>
                    }
                </td>
                <td>
                    @if (!c.IsSystem)
                    {
                        <a asp-action="Index" asp-route-editId="@c.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                        <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Xóa danh mục này?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted small">Chỉ xem</span>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="modal fade" id="categoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="categoryForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="categoryModalTitle">Thêm danh mục</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="Id" id="categoryId" value="@Model.Form.Id" />
                    <div class="mb-2">
                        <label class="form-label">Tên *</label>
                        <input name="Name" id="categoryName" value="@Model.Form.Name" class="form-control" required maxlength="100" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function clearCategoryForm() {
        document.getElementById('categoryModalTitle').innerText = 'Thêm danh mục';
        document.getElementById('categoryForm').action = '@Url.Action("Create")';
        document.getElementById('categoryId').value = '';
        document.getElementById('categoryName').value = '';
    }
    @if (Model.ShowFormModal)
    {
        <text>
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('categoryModalTitle').innerText = '@(Model.IsEdit ? "Sửa danh mục" : "Thêm danh mục")';
            document.getElementById('categoryForm').action = '@(Model.IsEdit ? Url.Action("Edit", new { id = Model.Form.Id }) : Url.Action("Create"))';
            new bootstrap.Modal(document.getElementById('categoryModal')).show();
        });
        </text>
    }
</script>
}
