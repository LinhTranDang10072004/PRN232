@model List<WalletDto>
@{
    ViewData["Title"] = "Ví cá nhân";
    var types = new Dictionary<string, string>
    {
        ["Cash"] = "Tiền mặt",
        ["Bank"] = "Ngân hàng",
        ["Momo"] = "Momo",
        ["Savings"] = "Tiết kiệm"
    };
}

<div class="d-flex justify-content-between mb-3">
    <h2>👛 Ví cá nhân</h2>
    <a asp-action="Create" class="btn btn-primary">+ Thêm ví</a>
</div>

<div class="row g-3">
    @foreach (var w in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100 @(w.Status == "Inactive" ? "opacity-50" : "")">
                <div class="card-body">
                    <h5 class="card-title">@w.Name</h5>
                    <p class="text-muted mb-1">@(types.GetValueOrDefault(w.Type ?? "", w.Type ?? ""))</p>
                    <p class="fs-4 fw-bold text-primary mb-3">@w.Balance.ToString("N0") đ</p>
                    @if (w.Status != "Inactive")
                    {
                        <a asp-action="Edit" asp-route-id="@w.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <form asp-action="Deactivate" method="post" class="d-inline" onsubmit="return confirm('Ngưng sử dụng ví này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@w.Id" />
                            <button class="btn btn-sm btn-outline-danger">Ngưng</button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Đã ngưng</span>
                    }
                </div>
            </div>
        </div>
    }
</div>
