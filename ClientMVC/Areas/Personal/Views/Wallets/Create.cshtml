@model WalletFormModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Sửa ví" : "Thêm ví";
    var isEdit = Model.Id.HasValue;
}

<h2 class="mb-3">@ViewData["Title"]</h2>
@if (!string.IsNullOrEmpty(Model.ErrorMessage)) { <div class="alert alert-danger">@Model.ErrorMessage</div> }

<form asp-action="@(isEdit ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post" class="card p-4 shadow-sm" style="max-width:480px">
    @Html.AntiForgeryToken()
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" class="form-select">
            <option value="Cash">Tiền mặt</option>
            <option value="Bank">Ngân hàng</option>
            <option value="Momo">Momo</option>
            <option value="Savings">Tiết kiệm</option>
        </select>
    </div>
    @if (!isEdit)
    {
        <div class="mb-3">
            <label asp-for="InitialBalance" class="form-label"></label>
            <input asp-for="InitialBalance" class="form-control" />
        </div>
    }
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
</form>
