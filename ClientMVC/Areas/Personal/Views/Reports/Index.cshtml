@using ClientMVC.Models.Personal
@{
    ViewData["Title"] = "Báo cáo";
    var month = (int)ViewBag.Month;
    var year = (int)ViewBag.Year;
    var summary = ViewBag.Summary as MonthlySummaryDto;
    var byCategory = ViewBag.ByCategory as List<CategoryReportDto> ?? new();
    var budgetStatus = ViewBag.BudgetStatus as List<BudgetStatusDto> ?? new();
    var yearly = ViewBag.Yearly as YearlyReportDto;
}

<h2 class="mb-3">📈 Báo cáo @month/@year</h2>

<form method="get" class="row g-2 mb-4" style="max-width:400px">
    <div class="col-4"><input name="month" value="@month" class="form-control" placeholder="Tháng" /></div>
    <div class="col-4"><input name="year" value="@year" class="form-control" placeholder="Năm" /></div>
    <div class="col-4"><button class="btn btn-primary w-100">Xem</button></div>
</form>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card p-3 shadow-sm">
            <div class="text-muted small">Tổng chi tháng</div>
            <div class="fs-4 fw-bold text-danger">@((summary?.TotalSpent ?? 0).ToString("N0")) đ</div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header">Theo danh mục</div>
            <ul class="list-group list-group-flush">
                @foreach (var c in byCategory)
                {
                    <li class="list-group-item d-flex justify-content-between"><span>@c.CategoryName</span><strong>@c.TotalSpent.ToString("N0")</strong></li>
                }
            </ul>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header">Budget — vượt / còn dư</div>
            <table class="table mb-0">
                @foreach (var b in budgetStatus)
                {
                    <tr class="@(b.IsExceeded ? "table-danger" : "")">
                        <td>@b.BudgetName</td>
                        <td>@b.SpentAmount.ToString("N0") / @b.LimitAmount.ToString("N0")</td>
                        <td class="@(b.IsExceeded ? "text-danger" : "text-success")">@(b.IsExceeded ? "Vượt" : $"Còn {b.RemainingAmount:N0}")</td>
                    </tr>
                }
            </table>
        </div>
    </div>
    @if (yearly != null)
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">Năm @yearly.Year — Tổng @yearly.TotalSpent.ToString("N0") đ</div>
                <ul class="list-group list-group-flush">
                    @foreach (var c in yearly.ByCategory)
                    {
                        <li class="list-group-item d-flex justify-content-between"><span>@c.CategoryName</span><strong>@c.TotalSpent.ToString("N0")</strong></li>
                    }
                </ul>
            </div>
        </div>
    }
</div>
