@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
    var summary = Model.Summary;
}

<h2 class="mb-4">Tổng quan tháng @(summary?.Month ?? DateTime.Today.Month)/@(summary?.Year ?? DateTime.Today.Year)</h2>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Tổng chi tiêu</div>
                <div class="fs-3 fw-bold text-danger">@((summary?.TotalSpent ?? 0).ToString("N0")) đ</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Số khoản chi</div>
                <div class="fs-3 fw-bold">@(summary?.ExpenseCount ?? 0)</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card border-0 shadow-sm">
            <div class="card-body">
                <div class="text-muted small">Thông báo chưa đọc</div>
                <div class="fs-3 fw-bold">@Model.UnreadNotifications</div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2 mb-4">
    <a asp-action="Calendar" asp-controller="Expenses" class="btn btn-primary">📅 Mở lịch chi tiêu</a>
    <a asp-action="Create" asp-controller="Expenses" class="btn btn-outline-primary">+ Thêm chi tiêu</a>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Budget tháng này</div>
            <div class="card-body p-0">
                @if (!Model.Budgets.Any())
                {
                    <p class="p-3 text-muted mb-0">Chưa có budget.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var b in Model.Budgets)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@b.BudgetName</span>
                                <span class="@(b.IsExceeded ? "text-danger" : "text-success")">
                                    @b.SpentAmount.ToString("N0") / @b.LimitAmount.ToString("N0")
                                </span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">Top danh mục</div>
            <div class="card-body p-0">
                @if (!Model.TopCategories.Any())
                {
                    <p class="p-3 text-muted mb-0">Chưa có dữ liệu.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var c in Model.TopCategories)
                        {
                            <li class="list-group-item d-flex justify-content-between">
                                <span>@c.CategoryName</span>
                                <strong>@c.TotalSpent.ToString("N0") đ</strong>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
