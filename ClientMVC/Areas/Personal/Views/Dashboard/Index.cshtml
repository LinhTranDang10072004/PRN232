@{
    ViewData["Title"] = "Dashboard cá nhân";
}

<div class="p-4 mb-4 bg-primary text-white rounded-3">
    <h1 class="display-6">Xin chào, @(ViewBag.FullName ?? ViewBag.Username)!</h1>
    <p class="mb-0">Quản lý ví chi tiêu cá nhân (Nhánh User)</p>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Chi tiêu</h5>
                <p class="card-text text-muted">Thêm, sửa, xóa khoản chi — lọc bằng OData.</p>
                <a asp-area="Personal" asp-controller="Expenses" asp-action="Index" class="btn btn-primary">Quản lý chi tiêu (CRUD)</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Danh mục</h5>
                <p class="card-text text-muted">Xem danh mục hệ thống, tự tạo danh mục riêng.</p>
                <a asp-area="Personal" asp-controller="Categories" asp-action="Index" class="btn btn-outline-primary">Mở danh mục</a>
            </div>
        </div>
    </div>
</div>
