@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center py-5">
    <h1>Quản lý chi tiêu</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <p class="lead">Xin chào, <strong>@User.Identity.Name</strong></p>
        @if (User.IsInRole("User"))
        {
            <a asp-area="Personal" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary me-2">Vào khu vực cá nhân</a>
            <a asp-area="Personal" asp-controller="Expenses" asp-action="Calendar" class="btn btn-outline-primary">📅 Lịch chi tiêu</a>
        }
    }
    else
    {
        <p class="lead">Hệ thống quản lý chi tiêu cá nhân và doanh nghiệp.</p>
        <a asp-controller="Auth" asp-action="Login" class="btn btn-primary me-2">Đăng nhập</a>
        <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-primary">Đăng ký</a>
    }
</div>
