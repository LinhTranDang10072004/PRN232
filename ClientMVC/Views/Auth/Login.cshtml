@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập — FinanceMe</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
</head>
<body class="home-page">

    <partial name="_MarketingNav" />

    <div class="auth-page">
        <div class="auth-card">

            <div class="auth-header">
                <a asp-controller="Home" asp-action="Index" class="auth-brand-icon" style="text-decoration:none;">💰</a>
                <h1 class="auth-title">Đăng nhập</h1>
                <p class="auth-subtitle">Chào mừng trở lại FinanceMe!</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    <span class="alert-icon">⚠️</span>
                    @Model.ErrorMessage
                </div>
            }

            <form asp-action="Login" asp-controller="Auth" method="post" novalidate>
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="form-group">
                    <label class="form-label" asp-for="Username"></label>
                    <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập hoặc email" autofocus autocomplete="username" />
                    <span asp-validation-for="Username" class="form-error"></span>
                </div>

                <div class="form-group">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                        <label class="form-label" asp-for="Password" style="margin-bottom:0"></label>
                    </div>
                    <input asp-for="Password" class="form-control" placeholder="Nhập mật khẩu" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="form-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full" style="margin-top:4px;">
                    Đăng nhập
                </button>
            </form>

            <p class="auth-footer">
                Chưa có tài khoản?
                <a asp-action="Register" asp-controller="Auth" style="font-weight:600;">Đăng ký ngay →</a>
            </p>

        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>
