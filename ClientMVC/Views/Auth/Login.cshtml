<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập — FinanceMe</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="style.css" />
</head>
<body>

    <div class="auth-page">
        <div class="auth-card">

            <!-- Header -->
            <div class="auth-header">
                <a href="index.html" class="auth-brand-icon" style="text-decoration:none;">💰</a>
                <h1 class="auth-title">Đăng nhập</h1>
                <p class="auth-subtitle">Chào mừng trở lại!</p>
            </div>

            <!-- Error (bỏ comment nếu có lỗi) -->
            <!--
            <div class="alert alert-danger">
              <span class="alert-icon">⚠️</span>
              Tên đăng nhập hoặc mật khẩu không đúng.
            </div>
            -->
            <!-- Form -->
            <form action="/Auth/Login" method="post" novalidate>
                <input type="hidden" name="__RequestVerificationToken" value="" />
                <input type="hidden" name="returnUrl" value="" />

                <div class="form-group">
                    <label class="form-label" for="Username">Tên đăng nhập</label>
                    <input type="text"
                           id="Username"
                           name="Username"
                           class="form-control"
                           placeholder="Nhập tên đăng nhập"
                           autofocus
                           autocomplete="username" />
                    <!-- <span class="form-error">⚠ Vui lòng nhập tên đăng nhập.</span> -->
                </div>

                <div class="form-group">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                        <label class="form-label" for="Password" style="margin-bottom:0">Mật khẩu</label>
                        <a href="#" style="font-size:0.8125rem;">Quên mật khẩu?</a>
                    </div>
                    <input type="password"
                           id="Password"
                           name="Password"
                           class="form-control"
                           placeholder="Nhập mật khẩu"
                           autocomplete="current-password" />
                    <!-- <span class="form-error">⚠ Vui lòng nhập mật khẩu.</span> -->
                </div>

                <button type="submit" class="btn btn-primary btn-full" style="margin-top:4px;">
                    Đăng nhập
                </button>
            </form>

            <p class="auth-footer">
                Chưa có tài khoản?
                <a href="register.html" style="font-weight:600;">Đăng ký ngay →</a>
            </p>

            <!-- Demo credentials -->
           

        </div>
    </div>

</body>
</html>