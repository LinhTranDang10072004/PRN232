@model RegisterViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng ký";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký — FinanceMe</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
</head>
<body class="home-page">

    <partial name="_MarketingNav" />

    <div class="auth-page">
        <div class="auth-card" style="max-width:460px;">

            <div class="auth-header">
                <a asp-controller="Home" asp-action="Index" class="auth-brand-icon" style="text-decoration:none;">💰</a>
                <h1 class="auth-title">Tạo tài khoản</h1>
                <p class="auth-subtitle">Bắt đầu quản lý tài chính ngay hôm nay</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    <span class="alert-icon">⚠️</span>
                    @Model.ErrorMessage
                </div>
            }

            <form asp-action="Register" asp-controller="Auth" method="post" novalidate>

                <div class="form-group">
                    <label class="form-label" asp-for="Username"></label>
                    <input asp-for="Username" class="form-control" placeholder="username" autocomplete="username" />
                    <span asp-validation-for="Username" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="form-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Password"></label>
                    <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" autocomplete="new-password" />
                    <span class="form-hint">Dùng kết hợp chữ hoa, chữ thường và số.</span>
                    <span asp-validation-for="Password" class="form-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full">
                    Tạo tài khoản
                </button>
            </form>

            <p class="auth-footer">
                Đã có tài khoản?
                <a asp-action="Login" asp-controller="Auth" style="font-weight:600;">Đăng nhập →</a>
            </p>

        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />

</body>
</html>
