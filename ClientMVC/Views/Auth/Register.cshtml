<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký — FinanceMe</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="style.css" />
</head>
<body>

    <div class="auth-page">
        <div class="auth-card" style="max-width:460px;">

            <!-- Header -->
            <div class="auth-header">
                <a href="index.html" class="auth-brand-icon" style="text-decoration:none;">💰</a>
                <h1 class="auth-title">Tạo tài khoản</h1>
                <p class="auth-subtitle">Bắt đầu quản lý tài chính ngay hôm nay</p>
            </div>

            <!-- Error -->
            <!--
            <div class="alert alert-danger">
              <span class="alert-icon">⚠️</span>
              Tên đăng nhập đã tồn tại. Vui lòng chọn tên khác.
            </div>
            -->
            <!-- Form -->
            <form action="/Auth/Register" method="post" novalidate>
                <input type="hidden" name="__RequestVerificationToken" value="" />

                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label" for="Username">Tên đăng nhập</label>
                        <input type="text"
                               id="Username"
                               name="Username"
                               class="form-control"
                               placeholder="username"
                               autocomplete="username" />
                        <!-- <span class="form-error">⚠ Bắt buộc nhập.</span> -->
                    </div>

                    <div class="form-group">
                        <label class="form-label" for="FullName">Họ và tên</label>
                        <input type="text"
                               id="FullName"
                               name="FullName"
                               class="form-control"
                               placeholder="Nguyễn Văn A"
                               autocomplete="name" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="Email">Email</label>
                    <input type="email"
                           id="Email"
                           name="Email"
                           class="form-control"
                           placeholder="you@example.com"
                           autocomplete="email" />
                    <!-- <span class="form-error">⚠ Email không hợp lệ.</span> -->
                </div>

                <div class="form-group">
                    <label class="form-label" for="Password">Mật khẩu</label>
                    <input type="password"
                           id="Password"
                           name="Password"
                           class="form-control"
                           placeholder="Tối thiểu 8 ký tự"
                           autocomplete="new-password" />
                    <span class="form-hint">Dùng kết hợp chữ hoa, chữ thường và số.</span>
                    <!-- <span class="form-error">⚠ Mật khẩu quá ngắn.</span> -->
                </div>

                <div class="form-check">
                    <input type="checkbox" id="agree" name="agree" />
                    <label for="agree">
                        Tôi đồng ý với
                        <a href="#">điều khoản sử dụng</a>
                        và
                        <a href="#">chính sách bảo mật</a>
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-full">
                    Tạo tài khoản
                </button>
            </form>

            <p class="auth-footer">
                Đã có tài khoản?
                <a href="login.html" style="font-weight:600;">Đăng nhập →</a>
            </p>

        </div>
    </div>

</body>
</html>